# ============================================================================
# deploy.sh  ·  configuration overrides
# ----------------------------------------------------------------------------
# Copy this file to `deploy.env` (same directory as deploy.sh) and fill in
# your values. `deploy.env` is gitignored — never commit it.
#
#   cp deploy.env.example deploy.env
#   chmod 600 deploy.env
#   vi deploy.env
#   sudo ./deploy.sh
#
# Any variable the script understands can be set here. Only the ones you
# actually want to override need to be present — leave the rest commented.
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Password for the 'postgres' superuser role. Used by deploy.sh to create
# the application role and database. Required unless you want the script
# to enable peer auth in pg_hba.conf instead.
POSTGRES_SUPERUSER_PASSWORD='change-me'

# Application DB role + database name (defaults are usually fine)
#DB_NAME='codecoder'
#DB_USER='codecoder'
# Leave DB_PASS empty to auto-generate on first run
#DB_PASS=''

# ── Host / TLS ──────────────────────────────────────────────────────────────
#DOMAIN='internal.in.deptagency.com'
#CERT_FILE='/etc/pki/tls/certs/${DOMAIN}.crt'
#KEY_FILE='/etc/pki/tls/private/${DOMAIN}.key'
#CHAIN_FILE=''

# ── Google OAuth (production mode) ──────────────────────────────────────────
# When both are set, the script flips QUIZ_DEV_MODE=false.
#GOOGLE_CLIENT_ID=''
#GOOGLE_CLIENT_SECRET=''

# ── Service tunables ────────────────────────────────────────────────────────
# APP_HOME is the target root on the VM. Under it deploy.sh creates:
#   $APP_HOME/backend/         (was quiz-certification/)
#   $APP_HOME/frontend/        (was app/)
#   $APP_HOME/content/source/  (was content-architecture/ — JSON source of truth)
#   $APP_HOME/content/frozen/  (was content-system/  — frozen HTML monolith)
#APP_USER='cca'
#APP_HOME='/opt/dept-anatomy'
#QUIZ_PORT='8000'
# QUIZ_WORKERS is pinned to 1 in deploy.sh until Phase 2a moves quiz_sessions
# into Postgres (C-12). Override here only if you have made the same fix
# locally; otherwise leave at the default.
#QUIZ_WORKERS='1'
