# ============================================================================
# DEPT Anatomy of Code — Directus (CMS) environment template
# Phase 4a. Copy to cms/.env and fill in. cms/.env is GITIGNORED — never commit
# real secrets. This template is committed; placeholders only.
#
# Directus is the editorial WRITE plane. It connects to the SAME Postgres the
# FastAPI app uses, as the per-env scoped role "directus_app" (prod) — created
# by Alembic migration 0008, Slice 4a-1. The role can DDL only directus_* tables
# and DML only the content tables — it CANNOT see attempts, quiz_sessions,
# signing_keys, or auth_audit (enforced at the DB GRANT level).
#
# REMOTE shared-instance design (2026-06 cutover): the Postgres is a REMOTE
# shared server (no longer co-resident on the VM), hosting a separate database
# AND a separate Directus role per environment — prod=codecoder/directus_app,
# staging=codecoder_staging/directus_app_stg, dev=codecoder_dev/directus_app_dev.
# Each role is GRANTed only on its own database, so a dev Directus credential
# can never reach prod. Connections are over TLS (DB_SSL=true). On the VM,
# deploy.sh writes these keys for you from DB_HOST/DB_NAME/DIRECTUS_DB_ROLE.
# ============================================================================

# ---------------------------------------------------------------------------
# Database — connect to the REMOTE shared Postgres as the per-env Directus role
# ---------------------------------------------------------------------------
DB_CLIENT=pg
DB_HOST=REMOTE_DB_HOST
DB_PORT=5432
# prod database is codecoder; for dev use codecoder_dev, staging codecoder_staging.
DB_DATABASE=codecoder
# prod role is directus_app; for dev use directus_app_dev, staging directus_app_stg.
DB_USER=directus_app
# Real scoped password from the secret store (never commit it). The remote
# instance authenticates with scram/md5 over TLS — there is no loopback `trust`.
DB_PASSWORD=CHANGE_ME
# TLS is REQUIRED to the remote instance (matches the app's sslmode=require).
DB_SSL=true
# When sslmode=require WITHOUT a provisioned CA, the server cert chain cannot be
# verified, so node-postgres must not reject it. This is acceptable for require
# (encryption without identity check) and MUST be documented as such:
DB_SSL__REJECT_UNAUTHORIZED=false
# For verify-full (preferred in prod): provision the CA, then instead set
#   DB_SSL__REJECT_UNAUTHORIZED=true
#   DB_SSL__CA=/etc/ssl/certs/pg-ca.crt
# Dev aside: if you tunnel to the remote DB over an SSH local-forward, point
# DB_HOST at 127.0.0.1 and the forwarded port; TLS still rides the tunnelled
# Postgres connection end-to-end.

# ---------------------------------------------------------------------------
# Directus core secrets (REQUIRED) — regenerate per environment.
# Generate with:  node -e "console.log(require('crypto').randomUUID())"
#   KEY    -> signs internal cache keys / instance identity
#   SECRET -> signs Directus session JWTs (rotating this logs everyone out)
# These are Directus-side only; they are NOT the FastAPI SECRET_KEY.
# ---------------------------------------------------------------------------
KEY=replace-with-random-uuid-key
SECRET=replace-with-random-uuid-secret

# ---------------------------------------------------------------------------
# Public URL — where Directus is reachable.
#   LOCAL: http://localhost:8055
#   PROD : behind Apache, either a subpath (https://<domain>/cms) or a
#          dedicated subdomain (https://cms.<domain>). 4a-3 owns the Apache
#          ProxyPass + WS-upgrade vhost. Whatever is chosen MUST match the
#          Google OAuth redirect URI registered in the Google console.
# ---------------------------------------------------------------------------
PUBLIC_URL=http://localhost:8055
PORT=8055
HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Bootstrap admin (break-glass local Directus account).
# Created by `directus bootstrap` on first boot. In prod, supply via the VM's
# secret manager, not git. This account is the fallback if Google SSO breaks.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@deptagency.com
ADMIN_PASSWORD=change-me-local-dev-only

# ---------------------------------------------------------------------------
# Storage — FINAL DECISION (2026-06-06): ALL app media lives in Postgres large
# objects (media_assets.large_object_oid + pg_largeobject) and is streamed by
# FastAPI /media/{video,image}/{asset_id} with HTTP Range. There is NO S3, NO
# object store, and NO filesystem media store — Postgres is the only database
# and the only place media bytes live. (This is Phase 0 decision C, kept; the
# earlier "move media to a storage adapter" idea is cancelled.)
#
# Directus therefore does NOT store app media. media_assets is bound in Directus
# as READ-ONLY metadata so editors can SEE/REFERENCE assets by id; uploads and
# bytes go ONLY through FastAPI /api/media/upload -> pg_largeobject.
#
# Directus still needs a storage location defined to boot (for incidental
# directus_files such as user avatars). Keep it local + tiny. App-media uploads
# into Directus Files MUST be disabled by permission (no role gets directus_files
# create) so nothing app-facing ever lands on disk. Do not configure S3.
# ---------------------------------------------------------------------------
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads   # Directus-internal only (avatars); NOT app media.

# ---------------------------------------------------------------------------
# Authentication — Google SSO for staff (deptagency.com only).
# A SEPARATE OAuth client from the FastAPI learner one (different redirect URI,
# different client id/secret). Redirect URI to register in the Google console:
#       <PUBLIC_URL>/auth/login/google/callback
#   LOCAL: http://localhost:8055/auth/login/google/callback
#   PROD : https://<domain>/cms/auth/login/google/callback   (subpath)
#       OR https://cms.<domain>/auth/login/google/callback   (subdomain)
# SSO posture (secure default — MUST match deploy.sh's CMS env block):
#   - ALLOW_PUBLIC_REGISTRATION=false: admins PRE-CREATE each staff Directus
#     user (matched to their @deptagency.com Google email). SSO then only LOGS
#     IN an existing user; it never self-provisions one. New staff get a
#     Directus account created for them before they first sign in.
#   - ALLOW_LIST=deptagency.com: defence-in-depth. Directus rejects any Google
#     account whose verified email host is not on this comma-separated list,
#     even if public registration were ever flipped on.
#   - DEFAULT_ROLE_ID: the role a self-registered user would land in. It is
#     USED ONLY IF public registration is enabled; with it false the value is
#     inert. We still set it to content_author (the least-privileged staff
#     role) so the contract is explicit and a future flip stays least-privilege.
#     Capture the id from bootstrap.sh output and paste it here.
# ---------------------------------------------------------------------------
AUTH_PROVIDERS=google
AUTH_GOOGLE_DRIVER=openid
AUTH_GOOGLE_CLIENT_ID=replace-with-staff-oauth-client-id
AUTH_GOOGLE_CLIENT_SECRET=replace-with-staff-oauth-client-secret
AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
AUTH_GOOGLE_IDENTIFIER_KEY=email
AUTH_GOOGLE_SCOPE=openid email profile
# Public self-registration is OFF — admins pre-create staff users (see above).
AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=false
# Least-privilege role for any self-registered user (inert while public
# registration is false). Fill from bootstrap.sh output.
AUTH_GOOGLE_DEFAULT_ROLE_ID=replace-with-content_author-role-id
# Domain allow-list — only @deptagency.com Google accounts may register/login.
# Directus matches the verified email against this comma-separated host list.
AUTH_GOOGLE_ALLOW_LIST=deptagency.com

# ---------------------------------------------------------------------------
# CORS — the FastAPI-served SPA origin(s). Directus is an authoring console,
# not a request-path dependency for the SPA, but CORS is enabled so an
# operator browsing the API explorer / preview works.
# ---------------------------------------------------------------------------
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:8080,http://localhost:8000

# ---------------------------------------------------------------------------
# Cache — Directus's own response cache (separate from FastAPI's content
# cache). Memory cache is fine for a single-VM editorial console.
# ---------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_STORE=memory
CACHE_TTL=30m
CACHE_AUTO_PURGE=true

# ---------------------------------------------------------------------------
# Flows / webhooks — REQUIRED for the cache-invalidation seam (§7.3).
# Flows are enabled by default; FLOWS_ENV_ALLOW_LIST lets a Flow's "Run Script"
# read these vars if a script-based trigger is ever needed. The Phase 4a Flow
# uses a Webhook (Request URL) operation, so no env allow-list is strictly
# required, but FASTAPI_WEBHOOK_URL is provided for clarity / reuse.
# ---------------------------------------------------------------------------
FLOWS_ENV_ALLOW_LIST=FASTAPI_WEBHOOK_URL
# Loopback cache-invalidation target (FastAPI cms webhook receiver, §7.3).
# Co-resident on the same VM; loopback only — network reachability is the auth.
FASTAPI_WEBHOOK_URL=http://127.0.0.1:8000/api/cms/webhook
# Loopback staff-role mirror target (FastAPI roles-sync receiver, 04 §7.2). The
# directus-extension-roles-sync hook POSTs {email, role} here on staff-role
# changes. Uses a hook's native fetch (NOT the Flow request operation), so the
# IMPORT_IP_DENY_LIST guard below does not apply — loopback works as-is.
FASTAPI_ROLES_SYNC_URL=http://127.0.0.1:8000/api/cms/roles-sync
# REQUIRED for the loopback webhook to work. Directus's request-operation SSRF
# guard defaults to "0.0.0.0,169.254.169.254"; the 0.0.0.0 entry expands to
# addLocalNetworkInterfaces() and BLOCKS 127.0.0.1, silently dropping the POST
# to the co-resident FastAPI. We drop 0.0.0.0 but keep the cloud-metadata IP
# (169.254.169.254) blocked. Directus and FastAPI are co-resident by design,
# so loopback egress is intended and safe.
IMPORT_IP_DENY_LIST=169.254.169.254

# ---------------------------------------------------------------------------
# Telemetry off (no phone-home from an internal tool).
# ---------------------------------------------------------------------------
TELEMETRY=false
