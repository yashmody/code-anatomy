# ============================================================================
# DEPT Anatomy of Code — Directus (CMS) environment template
# Phase 4a. Copy to cms/.env and fill in. cms/.env is GITIGNORED — never commit
# real secrets. This template is committed; placeholders only.
#
# Directus is the editorial WRITE plane. It connects to the SAME Postgres the
# FastAPI app uses (database "codecoder"), as the scoped role "directus_app"
# (created by Alembic migration 0008, Slice 4a-1). The role can DDL only
# directus_* tables and DML only the content tables — it CANNOT see attempts,
# quiz_sessions, signing_keys, or auth_audit (enforced at the DB GRANT level).
# ============================================================================

# ---------------------------------------------------------------------------
# Database — connect to the existing codecoder Postgres as directus_app
# ---------------------------------------------------------------------------
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=codecoder
DB_USER=directus_app
# LOCAL: Postgres pg_hba uses `trust` for 127.0.0.1/::1, so the password is
# IGNORED locally — any value works. We still set one as a one-off
# (ALTER ROLE directus_app LOGIN PASSWORD '...') so the same .env shape works
# on a password-authenticated VM. See README "Local DB auth".
# PROD: set a real scoped password; pg_hba on the VM should require md5/scram.
DB_PASSWORD=directus_local_dev
# Directus and Postgres are co-resident on one VM; no TLS needed on loopback.
# DB_SSL=false

# ---------------------------------------------------------------------------
# Directus core secrets (REQUIRED) — regenerate per environment.
# Generate with:  node -e "console.log(require('crypto').randomUUID())"
#   KEY    -> signs internal cache keys / instance identity
#   SECRET -> signs Directus session JWTs (rotating this logs everyone out)
# These are Directus-side only; they are NOT the FastAPI SECRET_KEY.
# ---------------------------------------------------------------------------
KEY=replace-with-random-uuid-key
SECRET=replace-with-random-uuid-secret

# ---------------------------------------------------------------------------
# Public URL — where Directus is reachable.
#   LOCAL: http://localhost:8055
#   PROD : behind Apache, either a subpath (https://<domain>/cms) or a
#          dedicated subdomain (https://cms.<domain>). 4a-3 owns the Apache
#          ProxyPass + WS-upgrade vhost. Whatever is chosen MUST match the
#          Google OAuth redirect URI registered in the Google console.
# ---------------------------------------------------------------------------
PUBLIC_URL=http://localhost:8055
PORT=8055
HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Bootstrap admin (break-glass local Directus account).
# Created by `directus bootstrap` on first boot. In prod, supply via the VM's
# secret manager, not git. This account is the fallback if Google SSO breaks.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@deptagency.com
ADMIN_PASSWORD=change-me-local-dev-only

# ---------------------------------------------------------------------------
# Storage — DEFAULT: local filesystem under cms/uploads (gitignored).
# Phase 4a only ENABLES the Directus Files capability; it does NOT move the
# existing media off Postgres large objects (media_assets.large_object_oid +
# pg_largeobject). That migration is a LATER GATED slice. FastAPI still owns
# the streaming /api/media/upload path against pg_largeobject; Directus Files
# is a separate, additive store for editor-managed images.
# ---------------------------------------------------------------------------
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads

# --- PROD storage flip to S3 (per the locked decision — uncomment + fill) ---
# To move Directus Files to S3 for volume, switch STORAGE_LOCATIONS to s3 and
# supply every var below. The local block above can stay defined; the active
# location is whatever STORAGE_LOCATIONS names.
# STORAGE_LOCATIONS=s3
# STORAGE_S3_DRIVER=s3
# STORAGE_S3_KEY=<aws-access-key-id>
# STORAGE_S3_SECRET=<aws-secret-access-key>
# STORAGE_S3_BUCKET=<bucket-name>
# STORAGE_S3_REGION=<region e.g. ap-south-1>
# STORAGE_S3_ENDPOINT=<https://s3.ap-south-1.amazonaws.com  OR  S3-compatible endpoint>
# STORAGE_S3_FORCE_PATH_STYLE=false
# STORAGE_S3_ACL=private

# ---------------------------------------------------------------------------
# Authentication — Google SSO for staff (deptagency.com only).
# A SEPARATE OAuth client from the FastAPI learner one (different redirect URI,
# different client id/secret). Redirect URI to register in the Google console:
#       <PUBLIC_URL>/auth/login/google/callback
#   LOCAL: http://localhost:8055/auth/login/google/callback
#   PROD : https://<domain>/cms/auth/login/google/callback   (subpath)
#       OR https://cms.<domain>/auth/login/google/callback   (subdomain)
# DEFAULT_ROLE_ID must be the Directus role id for content_author (the least-
# privileged staff role) — capture it from bootstrap.sh output and paste here.
# Domain restriction to deptagency.com is enforced two ways:
#   1) ALLOW_PUBLIC_REGISTRATION=true gates new SSO users into DEFAULT_ROLE_ID.
#   2) Domain allow-list below restricts which Google accounts may register.
# ---------------------------------------------------------------------------
AUTH_PROVIDERS=google
AUTH_GOOGLE_DRIVER=openid
AUTH_GOOGLE_CLIENT_ID=replace-with-staff-oauth-client-id
AUTH_GOOGLE_CLIENT_SECRET=replace-with-staff-oauth-client-secret
AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
AUTH_GOOGLE_IDENTIFIER_KEY=email
AUTH_GOOGLE_SCOPE=openid email profile
AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=true
# Role new SSO staff land in (content_author). Fill from bootstrap.sh output.
AUTH_GOOGLE_DEFAULT_ROLE_ID=replace-with-content_author-role-id
# Domain allow-list — only @deptagency.com Google accounts may register/login.
# Directus matches the verified email against this comma-separated host list.
AUTH_GOOGLE_ALLOW_LIST=deptagency.com

# ---------------------------------------------------------------------------
# CORS — the FastAPI-served SPA origin(s). Directus is an authoring console,
# not a request-path dependency for the SPA, but CORS is enabled so an
# operator browsing the API explorer / preview works.
# ---------------------------------------------------------------------------
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:8080,http://localhost:8000

# ---------------------------------------------------------------------------
# Cache — Directus's own response cache (separate from FastAPI's content
# cache). Memory cache is fine for a single-VM editorial console.
# ---------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_STORE=memory
CACHE_TTL=30m
CACHE_AUTO_PURGE=true

# ---------------------------------------------------------------------------
# Flows / webhooks — REQUIRED for the cache-invalidation seam (§7.3).
# Flows are enabled by default; FLOWS_ENV_ALLOW_LIST lets a Flow's "Run Script"
# read these vars if a script-based trigger is ever needed. The Phase 4a Flow
# uses a Webhook (Request URL) operation, so no env allow-list is strictly
# required, but FASTAPI_WEBHOOK_URL is provided for clarity / reuse.
# ---------------------------------------------------------------------------
FLOWS_ENV_ALLOW_LIST=FASTAPI_WEBHOOK_URL
# Loopback cache-invalidation target (FastAPI cms webhook receiver, §7.3).
# Co-resident on the same VM; loopback only — network reachability is the auth.
FASTAPI_WEBHOOK_URL=http://127.0.0.1:8000/api/cms/webhook
# REQUIRED for the loopback webhook to work. Directus's request-operation SSRF
# guard defaults to "0.0.0.0,169.254.169.254"; the 0.0.0.0 entry expands to
# addLocalNetworkInterfaces() and BLOCKS 127.0.0.1, silently dropping the POST
# to the co-resident FastAPI. We drop 0.0.0.0 but keep the cloud-metadata IP
# (169.254.169.254) blocked. Directus and FastAPI are co-resident by design,
# so loopback egress is intended and safe.
IMPORT_IP_DENY_LIST=169.254.169.254

# ---------------------------------------------------------------------------
# Telemetry off (no phone-home from an internal tool).
# ---------------------------------------------------------------------------
TELEMETRY=false
