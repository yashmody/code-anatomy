# Build-time only — installed under node@22 to run `directus-extension build`.
node_modules/
.DS_Store

# NOTE: dist/ is intentionally committed so the Docker prod shape
# (cms/docker-compose.yml binds ./extensions:/directus/extensions:ro) and the
# npm/systemd shape both load the built module with no deploy-time build.
# The repo-root .gitignore has a blanket `dist/` rule, so re-include ours here
# (a deeper .gitignore overrides the root for paths it covers).
!dist/
!dist/**
