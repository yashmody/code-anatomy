{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feed.schema.json",
  "title": "CODE-CODER Feed Item",
  "description": "A user-generated feed post. One composer, six types, shared media. Socially ordered, framework-tagged. Required text fields must be non-empty (minLength 1), matching what the composer enforces. The <=100-word limit on 'post' bodies cannot be expressed in JSON Schema (word count, not character count) and is enforced by validate.py and the composer UI.",
  "type": "object",
  "required": ["id", "type", "author", "status", "topics", "createdAt", "updatedAt", "engagement"],
  "properties": {
    "id": { "type": "string", "pattern": "^post\\.[a-z0-9]+$" },
    "type": { "enum": ["post", "video", "list", "card", "vocab", "scenario"] },
    "author": {
      "type": "object",
      "required": ["userId", "name"],
      "properties": {
        "userId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string" },
        "initials": { "type": "string", "maxLength": 3 },
        "verified": { "type": "boolean" }
      }
    },
    "status": { "enum": ["draft", "pending-review", "published", "flagged", "removed"] },
    "topics": { "type": "array", "items": { "type": "string" } },
    "frameworkRef": { "type": "string", "pattern": "^[a-z]+(\\.[a-z0-9]+){1,3}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "engagement": {
      "type": "object",
      "required": ["upvotes", "comments", "saves"],
      "properties": {
        "upvotes": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 },
        "saves": { "type": "integer", "minimum": 0 }
      }
    },
    "moderation": {
      "type": "object",
      "properties": {
        "flagCount": { "type": "integer", "minimum": 0 },
        "reviewedBy": { "type": ["string", "null"] },
        "reviewedAt": { "type": ["string", "null"] }
      }
    },
    "media": { "type": "array", "items": { "$ref": "#/$defs/media" } }
  },
  "allOf": [
    { "if": { "properties": { "type": { "const": "post" } } },
      "then": { "required": ["body"], "properties": { "title": { "type": "string" }, "body": { "type": "string", "minLength": 1 } } } },
    { "if": { "properties": { "type": { "const": "video" } } },
      "then": { "required": ["title", "durationSec"], "properties": { "title": { "type": "string", "minLength": 1 }, "hook": { "type": "string" }, "durationSec": { "type": "integer", "minimum": 1 }, "url": { "type": "string" } } } },
    { "if": { "properties": { "type": { "const": "list" } } },
      "then": { "required": ["title", "items"], "properties": { "title": { "type": "string", "minLength": 1 }, "intro": { "type": "string" }, "items": { "type": "array", "minItems": 1, "items": {
        "type": "object", "required": ["text"], "properties": { "text": { "type": "string", "minLength": 1 }, "note": { "type": "string" } } } } } } },
    { "if": { "properties": { "type": { "const": "card" } } },
      "then": { "required": ["title", "teaser"], "properties": { "title": { "type": "string", "minLength": 1 }, "teaser": { "type": "string", "minLength": 1 }, "linkUrl": { "type": "string" } } } },
    { "if": { "properties": { "type": { "const": "vocab" } } },
      "then": { "required": ["term", "definition"], "properties": { "term": { "type": "string", "minLength": 1 }, "definition": { "type": "string", "minLength": 1 } } } },
    { "if": { "properties": { "type": { "const": "scenario" } } },
      "then": { "required": ["prompt", "options", "correct", "verdict", "reveal"], "properties": {
        "prompt": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
        "correct": { "type": "integer", "minimum": 0 },
        "verdict": { "type": "string", "minLength": 1 },
        "reveal": { "type": "string", "minLength": 1 } } } }
  ],
  "$defs": {
    "media": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["image", "diagram"] },
        "alt": { "type": "string" },
        "caption": { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "image" } } },
          "then": { "required": ["url"], "properties": { "url": { "type": "string" }, "width": { "type": "integer" }, "height": { "type": "integer" } } } },
        { "if": { "properties": { "kind": { "const": "diagram" } } },
          "then": { "required": ["render"], "properties": {
            "render": { "enum": ["mermaid", "ascii", "image"] },
            "source": { "type": "string" },
            "url": { "type": "string" } } } }
      ]
    }
  }
}
