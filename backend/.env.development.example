# ============================================================================
# DEPT® Anatomy of Code — backend .env (development)
# ----------------------------------------------------------------------------
# Copy to .env and edit. Local dev defaults: SMTP and Google OAuth are
# stubbed; sign in with any email; sent mail lands in ./outbox/.
#
# REMOTE shared-instance design (2026-06 cutover):
#   There is ONE remote Postgres server. It hosts a SEPARATE database per
#   environment — prod=codecoder, staging=codecoder_staging, dev=codecoder_dev
#   — and a SEPARATE login role per environment. Isolation is by database +
#   role: a dev credential (app_dev on codecoder_dev) cannot reach prod, and a
#   prod credential cannot reach dev. Roles are cluster-global in Postgres but
#   GRANTs are per-database, so distinct role NAMES per env are what enforce the
#   boundary. Local development now connects to THIS remote dev database — no
#   local Postgres is installed (it took too much disk).
#   TLS is REQUIRED on every connection (sslmode=require minimum). DB credentials
#   come from the VM/host secret store, never from git — this file ships
#   placeholders only.
# ============================================================================

# ── Run mode ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# Legacy alias for the v1 flag. Will be removed in Phase 5b. Equivalent to
# APP_ENV=development; honoured only if APP_ENV is not set.
QUIZ_DEV_MODE=true

# ── Tier-1 secrets ─────────────────────────────────────────────────────────
# Generate a real value: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-CHANGE-IN-PROD-7f8a9b0c1d2e3f4a
APP_PAYLOAD_SECRET=dev-payload-secret-32bytes-long!

# Google OAuth — leave blank in dev to keep the local email-form path.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override (05 §4.1 / C-26). Leave blank to derive from APP_BASE_URL.
GOOGLE_REDIRECT_URI=

# SMTP — leave blank to write mail to ./outbox/.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply@deptagency.com
FROM_NAME=DEPT® Academy

# ── Allowlists ─────────────────────────────────────────────────────────────
# Email domain accepted for sign-in. Empty disables the check.
ALLOWED_DOMAIN=deptagency.com
# Comma-separated emails seeded as platform_admin on first boot.
ADMIN_EMAILS=
# Dev-only allowlist; never set outside development.
DEV_SEED_ADMINS=

# ── Database ───────────────────────────────────────────────────────────────
# Local dev now uses the REMOTE shared instance's dev database (codecoder_dev)
# — no local Postgres needed, which saves disk. TLS is required (sslmode=require);
# psycopg2/SQLAlchemy honour ?sslmode= in the URL query. Swap REMOTE_DB_HOST and
# the password for the real values from the secret store; never commit them.
DATABASE_URL=postgresql://app_dev:CHANGE_ME@REMOTE_DB_HOST:5432/codecoder_dev?sslmode=require
# Per-env Directus login role granted ONLY on codecoder_dev (see migration 0008).
# deploy.sh / Alembic read this so the dev Directus role is directus_app_dev,
# distinct from prod's directus_app — a dev credential can never touch prod.
DIRECTUS_DB_ROLE=directus_app_dev
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
# The OFFLINE smoke harness (scripts/smoke.sh) still forces sqlite and does NOT
# touch the remote DB — it stays self-contained and runs 15/15 with no network.
# To smoke-test against sqlite by hand instead of the remote dev DB:
#   DATABASE_URL=sqlite:///./q0.db

# ── Quiz / media tunables (will move to app_config in a later phase) ───────
COOLDOWN_DAYS=7
QUIZ_DURATION_MIN=45
QUESTIONS_PER_QUIZ=30
PASS_MARK_CORRECT=25
MAX_VIDEO_SIZE_MB=30
MAX_IMAGE_SIZE_MB=2.5
MAX_VIDEO_DURATION_SEC=60

# ── Cache TTLs (seconds; 06-caching-performance cross-ref) ────────────────
CACHE_TTL_FRAMEWORK=900
CACHE_TTL_FEED=30
CACHE_TTL_APP_CONFIG=60

# ── LLM seam (no provider clients in Phase 2d) ─────────────────────────────
LLM_PROVIDER=none
LLM_API_KEY=

# ── Cert HMAC keys (Phase 2c selects the right row at verify time) ─────────
# In dev these can stay unset; the legacy-prod row is used by default.
CERT_HMAC_LEGACY=
CERT_HMAC_DEV=

# ── Directus seam (Phase 4a) ───────────────────────────────────────────────
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_TOKEN=

# ── Ops ────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
CSP_REPORT_ONLY=true
