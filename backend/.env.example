# ============================================================================
# Q0 · Quiz Module · Environment configuration
# Copy to .env and edit. In dev mode, almost nothing here needs to change.
# ============================================================================

# --- Mode --------------------------------------------------------------------
# When true: dev email login (no Google OAuth), emails written to ./outbox/
# When false: real Google OAuth required, real SMTP required
QUIZ_DEV_MODE=true

# --- Session -----------------------------------------------------------------
# Generate a new one for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-CHANGE-IN-PROD-7f8a9b0c1d2e3f4a

# --- Certificate signing (Phase 2c, see docs/architecture/v2/07 §8) ----------
# Cert HMAC is decoupled from SECRET_KEY in v2 so rotating session secrets
# never invalidates already-issued certificates. The signing_keys table
# (03 §2.5) stores metadata; the byte material lives here as env vars.
#
# CERT_HMAC_LEGACY: the original SECRET_KEY at v2 cutover. Operators MUST
# mirror the production SECRET_KEY value here on first deploy of Phase 2c so
# existing certs (whose signing_key_id points at the 'legacy-prod' row)
# continue to verify byte-identical. Never rotate this — that would break
# every issued cert. Rotate CERT_HMAC_PROD instead, then flip can_verify on
# the legacy-prod row when its 5-year window closes.
CERT_HMAC_LEGACY=
# Active production signing key — rotation target. Insert a 'prod-YYYY-NN'
# row in signing_keys with env_var_name='CERT_HMAC_PROD' to start using.
CERT_HMAC_PROD=
# Per-environment dev / staging keys. These MUST differ from CERT_HMAC_PROD
# so a forged DEV cert cannot validate against the production key.
CERT_HMAC_DEV=
CERT_HMAC_STG=

# APP_ENV drives the cert-ID prefix, PDF watermark, and verify-page badge.
# One of: production | staging | development. Defaults to 'production' if
# unset so a misconfigured box never silently downgrades cert hygiene.
#  - production : cert IDs stay CCA-F-… ; no watermark ; verifier is silent
#  - staging    : cert IDs become STG-CCA-F-… ; ochre "STAGING" watermark
#  - development: cert IDs become DEV-CCA-F-… ; ochre "DEVELOPMENT" watermark
APP_ENV=production

# --- Domain restriction ------------------------------------------------------
# Only emails ending in this domain can sign in
ALLOWED_DOMAIN=deptagency.com

# --- First-admin seed (Phase 2b) --------------------------------------------
# Comma-separated emails that get platform_admin granted idempotently by
# `scripts/seed_roles.py` (run once after `alembic upgrade head`). Without
# this, a fresh DB has no admin and nobody can grant roles.
ADMIN_EMAILS=

# --- Google OAuth (only used when QUIZ_DEV_MODE=false) -----------------------
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- SMTP (only used when QUIZ_DEV_MODE=false) -------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply@deptagency.com
FROM_NAME=DEPT® Academy

# --- Quiz behaviour ----------------------------------------------------------
# Number of questions per attempt (randomly sampled from the pool for that level)
QUESTIONS_PER_QUIZ=30
# Absolute number of correct answers required to pass (e.g. 25 of 30).
# This is the single source of truth for passing — the percentage is derived.
PASS_MARK_CORRECT=25
# Time limit per attempt, in minutes
QUIZ_DURATION_MIN=45
# Days a candidate must wait before retaking after a fail
COOLDOWN_DAYS=7

# --- Database ----------------------------------------------------------------
# deploy.sh auto-generates this for the VM.  For local dev with Postgres:
#   DATABASE_URL=postgresql://localhost/codecoder
# To fall back to SQLite (no extensions like hstore):
#   DATABASE_URL=sqlite:///./q0.db
DATABASE_URL=postgresql://codecoder:secret@localhost:5432/codecoder
