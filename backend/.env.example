# ============================================================================
# Q0 · Quiz Module · Environment configuration
# Copy to .env and edit. In dev mode, almost nothing here needs to change.
# ============================================================================

# --- Mode --------------------------------------------------------------------
# When true: dev email login (no Google OAuth), emails written to ./outbox/
# When false: real Google OAuth required, real SMTP required
QUIZ_DEV_MODE=true

# --- Session -----------------------------------------------------------------
# Generate a new one for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-CHANGE-IN-PROD-7f8a9b0c1d2e3f4a

# --- Domain restriction ------------------------------------------------------
# Only emails ending in this domain can sign in
ALLOWED_DOMAIN=deptagency.com

# --- Google OAuth (only used when QUIZ_DEV_MODE=false) -----------------------
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- SMTP (only used when QUIZ_DEV_MODE=false) -------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply@deptagency.com
FROM_NAME=DEPT® Academy

# --- Quiz behaviour ----------------------------------------------------------
# Number of questions per attempt (randomly sampled from the pool for that level)
QUESTIONS_PER_QUIZ=30
# Absolute number of correct answers required to pass (e.g. 25 of 30).
# This is the single source of truth for passing — the percentage is derived.
PASS_MARK_CORRECT=25
# Time limit per attempt, in minutes
QUIZ_DURATION_MIN=45
# Days a candidate must wait before retaking after a fail
COOLDOWN_DAYS=7

# --- Database ----------------------------------------------------------------
# deploy.sh auto-generates this for the VM.  For local dev with Postgres:
#   DATABASE_URL=postgresql://localhost/codecoder
# To fall back to SQLite (no extensions like hstore):
#   DATABASE_URL=sqlite:///./q0.db
DATABASE_URL=postgresql://codecoder:secret@localhost:5432/codecoder
