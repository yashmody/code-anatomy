# ============================================================================
# DEPT® Anatomy of Code — backend .env (staging)
# ----------------------------------------------------------------------------
# Mirror of .env.production.example, but on the staging Google OAuth client
# and staging mailbox. APP_ENV=staging is enforced — Settings.validate_for_env
# refuses to start if dev defaults are still present.
#
# REMOTE shared-instance design (2026-06 cutover):
#   ONE remote Postgres server hosts a SEPARATE database + login role per
#   environment. Staging uses database codecoder_staging with the app role
#   app_staging and the Directus role directus_app_stg, each GRANTed only on
#   codecoder_staging — so a staging credential cannot reach prod or dev, and
#   vice versa. TLS is REQUIRED (sslmode=require minimum). DB credentials come
#   from the host secret store, never git — placeholders only below.
# ============================================================================

# ── Run mode ────────────────────────────────────────────────────────────────
APP_ENV=staging
APP_BASE_URL=https://staging.internal.in.deptagency.com

# ── Tier-1 secrets — MUST be rotated to real values before boot ────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
APP_PAYLOAD_SECRET=

# Per-env Google OAuth client (separate from prod). Redirect URI registered
# with Google must match APP_BASE_URL + /auth/google/callback (or, if you
# need a non-derived path, set GOOGLE_REDIRECT_URI explicitly per 05 §4.1).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Staging mailbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply-staging@deptagency.com
FROM_NAME=DEPT® Academy (Staging)

# ── Allowlists ─────────────────────────────────────────────────────────────
ALLOWED_DOMAIN=deptagency.com
# REQUIRED in non-dev. Comma-separated platform_admin allowlist.
ADMIN_EMAILS=

# ── Database ───────────────────────────────────────────────────────────────
# DATABASE_URL carries the DB password — keep this file 0600 on the host.
# Remote shared instance, staging database, over TLS. Fill in REMOTE_DB_HOST and
# the app_staging password from the secret store. sslmode=require is the minimum;
# use verify-full if a CA bundle is provisioned (append &sslrootcert=/path/ca.crt).
#   DATABASE_URL=postgresql://app_staging:CHANGE_ME@REMOTE_DB_HOST:5432/codecoder_staging?sslmode=require
DATABASE_URL=
# NOTE: DIRECTUS_DB_ROLE / DIRECTUS_URL / DIRECTUS_ADMIN_TOKEN removed in ARCH-3.
# The directus_app_stg role stays in the DB until ARCH-4's drop-role migration.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ── Quiz / media tunables (transitional — app_config takes over in 4c) ─────
COOLDOWN_DAYS=7
QUIZ_DURATION_MIN=45
QUESTIONS_PER_QUIZ=30
PASS_MARK_CORRECT=25
MAX_VIDEO_SIZE_MB=30
MAX_IMAGE_SIZE_MB=2.5
MAX_VIDEO_DURATION_SEC=60

# ── Cache TTLs ─────────────────────────────────────────────────────────────
CACHE_TTL_FRAMEWORK=900
CACHE_TTL_FEED=30
CACHE_TTL_APP_CONFIG=60

# ── LLM seam ───────────────────────────────────────────────────────────────
LLM_PROVIDER=none
LLM_API_KEY=

# ── Cert HMAC keys ────────────────────────────────────────────────────────
# Staging signs with CERT_HMAC_STG (the signing_keys row environment=staging).
CERT_HMAC_LEGACY=
CERT_HMAC_STG=

# ── Ops ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Initial baking period: report-only CSP, flip to enforcing after.
CSP_REPORT_ONLY=true
