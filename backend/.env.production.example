# ============================================================================
# DEPT® Anatomy of Code — backend .env (production)
# ----------------------------------------------------------------------------
# Production has NO defaults for any Tier-1 secret. Settings.validate_for_env
# refuses to start with APP_ENV=production if SECRET_KEY or APP_PAYLOAD_SECRET
# still carry the dev defaults, or if ALLOWED_DOMAIN is empty.
#
# REMOTE shared-instance design (2026-06 cutover):
#   ONE remote Postgres server hosts a SEPARATE database + login role per
#   environment. Production uses database codecoder with the app role app_prod
#   and the Directus role directus_app, each GRANTed only on codecoder — so a
#   prod credential cannot reach the dev/staging databases, and a dev/staging
#   credential cannot reach prod. TLS is REQUIRED; prefer sslmode=verify-full
#   with a provisioned CA so the server identity is checked (sslmode=require is
#   the floor). DB credentials come from the host secret store, never git.
# ============================================================================

# ── Run mode ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_BASE_URL=https://internal.in.deptagency.com

# ── Tier-1 secrets — MUST be set ───────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
APP_PAYLOAD_SECRET=

# Production Google OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override (05 §4.1 / C-26). Leave blank to derive from APP_BASE_URL.
GOOGLE_REDIRECT_URI=

# Production SMTP relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
FROM_EMAIL=no-reply@deptagency.com
FROM_NAME=DEPT® Academy

# ── Allowlists ─────────────────────────────────────────────────────────────
ALLOWED_DOMAIN=deptagency.com
# REQUIRED. Comma-separated emails seeded as platform_admin.
ADMIN_EMAILS=

# ── Database ───────────────────────────────────────────────────────────────
# DATABASE_URL carries the DB password — keep this file 0600 on the host.
# Remote shared instance, prod database, over TLS. Fill in REMOTE_DB_HOST and the
# app_prod password from the secret store. Prefer verify-full with a CA bundle
# (so the server certificate is validated, defeating MITM); fall back to require
# only if no CA is provisioned:
#   verify-full: postgresql://app_prod:CHANGE_ME@REMOTE_DB_HOST:5432/codecoder?sslmode=verify-full&sslrootcert=/etc/ssl/certs/pg-ca.crt
#   require:     postgresql://app_prod:CHANGE_ME@REMOTE_DB_HOST:5432/codecoder?sslmode=require
DATABASE_URL=
# Per-env Directus login role granted ONLY on codecoder (migration 0008).
DIRECTUS_DB_ROLE=directus_app
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ── Quiz / media tunables (transitional — app_config takes over in 4c) ─────
COOLDOWN_DAYS=7
QUIZ_DURATION_MIN=45
QUESTIONS_PER_QUIZ=30
PASS_MARK_CORRECT=25
MAX_VIDEO_SIZE_MB=30
MAX_IMAGE_SIZE_MB=2.5
MAX_VIDEO_DURATION_SEC=60

# ── Cache TTLs ─────────────────────────────────────────────────────────────
CACHE_TTL_FRAMEWORK=900
CACHE_TTL_FEED=30
CACHE_TTL_APP_CONFIG=60

# ── LLM seam ───────────────────────────────────────────────────────────────
LLM_PROVIDER=none
LLM_API_KEY=

# ── Cert HMAC keys ────────────────────────────────────────────────────────
# Production verifies legacy certs with CERT_HMAC_LEGACY, signs new ones
# with CERT_HMAC_PROD (Phase 2c flips the verifier).
CERT_HMAC_LEGACY=
CERT_HMAC_PROD=

# ── Directus seam (Phase 4a) ───────────────────────────────────────────────
DIRECTUS_URL=https://internal.in.deptagency.com/cms
DIRECTUS_ADMIN_TOKEN=

# ── Ops ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Flip to false after the CSP report-only baking window closes.
CSP_REPORT_ONLY=false
