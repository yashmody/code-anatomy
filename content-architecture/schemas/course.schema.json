{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "course.schema.json",
  "title": "CODE-CODER Course Section",
  "description": "A chapter file — one framework letter, block-based prose rendered by Scroll + Read modes.",
  "type": "object",
  "required": ["frameworkAddress", "title", "sections"],
  "additionalProperties": false,
  "properties": {
    "frameworkAddress": { "type": "string", "pattern": "^[a-z]+(\\.[a-z0-9]+){1,3}$" },
    "title": { "type": "string", "minLength": 1 },
    "tag": { "type": "string" },
    "status": { "enum": ["draft", "review", "published", "archived"] },
    "scan": { "type": "array", "items": { "type": "string" }, "maxItems": 6 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/subsection" }
    }
  },
  "$defs": {
    "subsection": {
      "type": "object",
      "required": ["id", "blocks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z]+(\\.[a-z0-9-]+){1,4}$" },
        "title": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "blocks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/block" } }
      }
    },
    "block": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "page": { "type": "integer", "minimum": 1 },
        "collapsed": { "type": "boolean" }
      },
      "allOf": [
        { "if": { "properties": { "type": { "const": "chapter-open" } } },
          "then": { "required": ["drop", "html"], "properties": { "drop": { "type": "string", "maxLength": 1 }, "html": { "type": "string" } } } },
        { "if": { "properties": { "type": { "const": "lead" } } },
          "then": { "required": ["html"] } },
        { "if": { "properties": { "type": { "const": "prose" } } },
          "then": { "required": ["html"] } },
        { "if": { "properties": { "type": { "const": "heading" } } },
          "then": { "required": ["html"] } },
        { "if": { "properties": { "type": { "const": "quote" } } },
          "then": { "required": ["html"] } },
        { "if": { "properties": { "type": { "const": "code" } } },
          "then": { "required": ["code"], "properties": { "lang": { "type": "string" }, "code": { "type": "string" } } } },
        { "if": { "properties": { "type": { "const": "callout" } } },
          "then": { "required": ["variant", "html"], "properties": { "variant": { "enum": ["why", "tip", "pitfall", "before-after"] }, "html": { "type": "string" } } } },
        { "if": { "properties": { "type": { "const": "tierlist" } } },
          "then": { "required": ["items"], "properties": { "items": { "type": "array", "items": {
            "type": "object", "required": ["label"], "properties": { "n": { "type": "string" }, "label": { "type": "string" }, "note": { "type": "string" } } } } } } },
        { "if": { "properties": { "type": { "const": "architects-review" } } },
          "then": { "required": ["items"], "properties": { "label": { "type": "string" }, "items": { "type": "array", "items": { "type": "string" } } } } },
        { "if": { "properties": { "type": { "const": "chips" } } },
          "then": { "required": ["items"], "properties": { "items": { "type": "array", "items": { "type": "string" } } } } },
        { "if": { "properties": { "type": { "const": "notes" } } },
          "then": { "required": ["items"], "properties": { "items": { "type": "array", "items": { "type": "string" } } } } },
        { "if": { "properties": { "type": { "const": "map" } } },
          "then": { "required": ["rows"], "properties": { "title": { "type": "string" }, "rows": { "type": "array", "items": {
            "type": "object", "required": ["q", "c"], "properties": { "q": { "type": "string" }, "c": { "type": "string" } } } } } } },
        { "if": { "properties": { "type": { "const": "diagram" } } },
          "then": { "required": ["render"], "properties": { "render": { "enum": ["ascii", "mermaid", "table", "versus", "nodes", "flow"] }, "title": { "type": "string" } } } },
        { "if": { "properties": { "type": { "const": "cardgrid" } } },
          "then": { "required": ["cards"], "properties": { "columns": { "type": "integer", "minimum": 2, "maximum": 6 }, "cards": { "type": "array", "items": {
            "type": "object", "required": ["title"], "properties": { "eyebrow": { "type": "string" }, "title": { "type": "string" }, "body": { "type": "string" } } } } } } }
      ]
    }
  }
}
