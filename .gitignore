# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
# v2 explicit (any .venv anywhere is already covered, but list the canonical
# locations so it's obvious nothing under backend/ leaks into a commit):
backend/.venv/
backend/.pytest_cache/

# --- Secrets / local config ---
.env
.env.local
.claude/settings.local.json
deploy.env

# --- Dev-only shims (never ship to prod) ---
# Phase 1 (v2): quiz-certification/ renamed to backend/; dev_quiz.py removed.
backend/app/dev_quiz.py

# --- Runtime data (Q0 quiz) ---
backend/q0.db
backend/q0.db-journal
backend/.run-logs/
backend/quiz_results/*.json
backend/outbox/*.eml
backend/certificates/*.pdf

# --- Directus CMS (Phase 4a) — runtime-only, never committed ---
# node_modules/ is already covered by the broad rule below, but list the
# canonical cms locations so it is obvious nothing under cms/ leaks into a
# commit. The .env.example IS tracked (template); the real .env is not.
cms/node_modules/
cms/.env
cms/uploads/
cms/database/
cms/.directus/
cms/extensions/node_modules/

# --- Node / Expo (sample app) ---
node_modules/
.expo/
dist/
.expo-shared/
*.log

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors ---
.idea/
.vscode/
*.swp

# Legacy v1 paths — kept for safety on cross-branch checkouts. v2 layout
# moves content-architecture/ → content/source/ and quiz-certification/ →
# backend/, but anyone still on a pre-v2 branch should not commit these.
content-architecture/venv/
quiz-certification/.venv/
quiz-certification/quiz_results/
quiz-certification/certificates/
quiz-certification/outbox/

# --- Media (large binaries — keep out of git; serve locally / from a CDN) ---
# Root-anchored: the broad `media/` pattern (pre-v2) swallowed
# backend/app/modules/media/*.py too, breaking fresh clones. Narrow to the
# repo-root media/ folder only.
/media/
assets/*.mp4
